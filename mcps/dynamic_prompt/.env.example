# dynamic_prompt MCPサーバーの環境変数。
# 環境変数が優先され、未設定のものだけ mcps/dynamic_prompt/.env から読み込まれる。
# このファイルを .env にコピーして使う (.env は *.env として gitignore 済み)。

# --- トランスポート / サーバー ---
# TRANSPORT=stdio          # stdio (既定) / http。http はデプロイ向け
# HOST=0.0.0.0             # HTTP モード時のバインドホスト
# PORT=8080                # HTTP モード時のポート

# --- 設定ファイルの置き場所 ---
# PROMPTS_URI=             # 未設定なら src/dynamic_prompt/prompts/ を使用。
#                          # /abs/path または gs://bucket/prefix も指定可
# CONFIG_TTL_SECONDS=60    # 設定キャッシュの TTL 秒 (0 以下で自動 refresh 無効)

# --- DB ---
# DB_PATH=                 # 未設定なら src/dynamic_prompt/vocab.db

# --- OAuth 認証 (HTTP モードで保護したい場合のみ) ---
# GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# SERVICE_URL=http://localhost:8080          # OAuth の base_url
# ALLOWED_EMAILS=a@example.com,b@example.com # 許可するメールアドレス (カンマ区切り)
